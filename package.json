{
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "pnpm --filter @ifi/oh-pi-core build && pnpm -r --filter=!@ifi/oh-pi-core run build",
		"build:fast": "pnpm --filter @ifi/oh-pi-core run build:fast && pnpm -r --filter=!@ifi/oh-pi-core run build:fast",
		"typecheck": "pnpm --filter @ifi/oh-pi-core build && pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli --filter @ifi/pi-spec --filter @ifi/pi-web-client --filter @ifi/pi-web-server run typecheck",
		"verify:completion": "pnpm exec vitest run packages/subagents/tests/commands.test.ts",
		"security:allowlist": "node ./scripts/security/check-dependency-allowlist.mjs",
		"security:audit:prod": "node ./scripts/security/run-pnpm-audit.mjs --prod --audit-level=high",
		"security:audit:dev": "node ./scripts/security/run-pnpm-audit.mjs -D --audit-level=high",
		"security:check": "pnpm security:allowlist && pnpm security:audit:prod && pnpm security:audit:dev",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:patch-coverage": "pnpm tsx ./scripts/check-patch-coverage.ts --threshold 100 --lcov coverage/lcov.info",
		"bench": "pnpm bench:startup && pnpm bench:runtime && pnpm bench:extensions-render && pnpm bench:live-runtime",
		"bench:startup": "OH_PI_RUN_BENCHMARKS=1 pnpm exec vitest run benchmarks/startup/startup-bench.test.ts",
		"bench:runtime": "OH_PI_RUN_BENCHMARKS=1 pnpm exec vitest run benchmarks/runtime/runtime-bench.test.ts",
		"bench:extensions-render": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./benchmarks/extensions-render-performance.ts",
		"bench:live-runtime": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./benchmarks/live-runtime-behavior.ts",
		"verify:compiled-tarballs": "node ./scripts/verify-compiled-tarballs.mjs",
		"verify:published-packages": "node ./scripts/verify-published-packages.mjs",
		"verify:pi-compat": "node ./scripts/verify-pi-compat.mjs",
		"pi:switch": "node --experimental-strip-types ./scripts/pi-source-switch.mts",
		"pi:local": "node --experimental-strip-types ./scripts/pi-source-switch.mts local",
		"pi:published": "node --experimental-strip-types ./scripts/pi-source-switch.mts remote",
		"models:refresh-intelligence": "node ./scripts/generate-model-intelligence-snapshot.mjs",
		"mdt": "mdt",
		"docs:dev": "pnpm --filter @ifi/oh-pi-docs dev",
		"docs:build": "pnpm --filter @ifi/oh-pi-docs build",
		"docs:sync": "pnpm --filter @ifi/oh-pi-docs docs:sync",
		"docs:list": "pnpm mdt list",
		"docs:update": "pnpm mdt update",
		"docs:check": "pnpm mdt check",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --fix .",
		"lint:type-aware": "oxlint --deny-warnings --type-aware .",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"check": "pnpm format:check && pnpm lint"
	},
	"devDependencies": {
		"@earendil-works/pi-agent-core": "0.78.1",
		"@earendil-works/pi-ai": "0.78.1",
		"@earendil-works/pi-coding-agent": "0.78.1",
		"@earendil-works/pi-tui": "0.78.1",
		"@ifi/mdt": "^0.7.0",
		"@types/node": "^22.15.0",
		"@typescript/native-preview": "7.0.0-dev.20260426.1",
		"@vitest/coverage-v8": "^4.1.5",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"oxlint-tsgolint": "^0.22.0",
		"tsdown": "^0.21.10",
		"tsx": "^4.20.6",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"pi": {
		"extensions": [
			"./packages/extensions/extensions/answer.ts",
			"./packages/extensions/extensions/watchdog.ts",
			"./packages/extensions/extensions/auto-update.ts",
			"./packages/extensions/extensions/btw.ts",
			"./packages/extensions/extensions/compact-header.ts",
			"./packages/extensions/extensions/custom-footer.ts",
			"./packages/extensions/extensions/external-editor.ts",
			"./packages/extensions/extensions/git-guard.ts",
			"./packages/extensions/extensions/scheduler.ts",
			"./packages/extensions/extensions/shell-format.ts",
			"./packages/extensions/extensions/tool-metadata.ts",
			"./packages/extensions/extensions/usage-tracker.ts",
			"./packages/extensions/extensions/worktree.ts",
			"./packages/background-tasks/index.ts",
			"./packages/diagnostics/index.ts",
			"./packages/subagents/index.ts",
			"./packages/subagents/notify.ts",
			"./packages/plan/index.ts",
			"./packages/spec/extension/index.ts",
			"./packages/web-remote/index.ts",
			"./packages/cursor/index.ts",
			"./packages/ollama/index.ts",
			"./packages/analytics-extension/index.ts"
		],
		"prompts": [
			"./packages/prompts/prompts"
		],
		"skills": [
			"./packages/skills/skills"
		],
		"themes": [
			"./packages/themes/themes"
		]
	}
}
