		"directory": "packages/monopi__analytics-dashboard"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:server": "npx tsx src/server/index.ts",
		"dev:full": "concurrently \"vite\" \"npx tsx src/server/index.ts\"",
		"build": "vite build",
		"build:check": "tsgo --noEmit && vite build",
		"build:fast": "vite build",
		"preview": "vite preview",
		"typecheck": "tsgo --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@monopi/analytics-db": "0.5.1",
