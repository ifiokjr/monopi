		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"recharts": "^3.9.2",
		"tailwind-merge": "^3.6.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
