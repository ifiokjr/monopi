{
	"name": "@monopi/provider-ollama",
	"version": "0.5.1",
	"description": "Experimental Ollama provider for pi with local discovery and cloud login support.",
	"keywords": [
		"cloud",
		"experimental",
		"local",
		"ollama",
		"pi",
		"pi-coding-agent",
		"pi-package",
		"provider"
	],
	"homepage": "https://github.com/ifiokjr/monopi/tree/main/packages/monopi__provider-ollama",
	"bugs": {
		"url": "https://github.com/ifiokjr/monopi/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ifiokjr/monopi.git",
		"directory": "packages/monopi__provider-ollama"
	},
	"files": [
		"*.ts",
		"README.md",
		"!**/*.test.ts",
		"!tests/**"
